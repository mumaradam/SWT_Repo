                  <div class="cta-buttons">
                    <a href="destinations.html" class="btn btn-primary me-3">Explore Destinations</a>
                    <a href="https://www.facebook.com/seihaworldtravel" target="_blank" class="btn btn-outline">Chat with an Expert</a>
                  </div>
                </div>
              </div>
            </div>
